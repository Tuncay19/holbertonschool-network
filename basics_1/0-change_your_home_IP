#!/usr/bin/env bash
# Configures /etc/hosts to redirect localhost and facebook.com

# Change localhost to resolve to 127.0.0.2
sudo sed -i 's/127.0.0.1 localhost/127.0.0.2 localhost/g' /etc/hosts

# Change facebook.com to resolve to 8.8.8.8
# If facebook.com already exists in hosts, update it; otherwise, append it.
if grep -q "facebook.com" /etc/hosts; then
    sudo sed -i 's/.*facebook.com/8.8.8.8 facebook.com/' /etc/hosts
else
    echo "8.8.8.8 facebook.com" | sudo tee -a /etc/hosts > /dev/null
fi
