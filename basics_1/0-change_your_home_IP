#!/usr/bin/env bash
# Configures /etc/hosts without using sed -i to avoid 'resource busy' error

# Replace 127.0.0.1 with 127.0.0.2 and update facebook.com
# We read the file, modify it in memory, and overwrite it using 'tee'
sed 's/127.0.0.1/127.0.0.2/g' /etc/hosts | sed 's/.*facebook.com/8.8.8.8 facebook.com/' > hosts.temp

# If facebook.com wasn't there, add it
if ! grep -q "facebook.com" hosts.temp; then
    echo "8.8.8.8 facebook.com" >> hosts.temp
fi

# Overwrite the real /etc/hosts
cat hosts.temp | sudo tee /etc/hosts > /dev/null
rm hosts.temp
